# ── Octagonl SSO (required) ──────────────────────────────────
VITE_OIDC_CLIENT_ID=<your-app-registration-client-id>
VITE_OIDC_AUTHORITY=https://login.octago.nl/<tenant-id>
VITE_REDIRECT_URI=http://localhost:5173

# ── Platform API (optional) ─────────────────────────────────
VITE_PLATFORM_API_BASE_URL=https://api.octago.nl
VITE_OIDC_API_SCOPE=api://<platform-api-client-id>/access_as_user
